{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["es2020"],
    "isolatedModules": false,
    "incremental": false,
    "plugins": []
  },
  "include": [
    "tests/**/*.ts",
    "src/lib/active-org-core.ts",
    "src/lib/invite-acceptance.ts",
    "src/lib/github-installation-core.ts",
    "src/lib/github-repo-core.ts",
    "src/lib/billing-webhook-core.ts",
    "src/lib/report-suppressions-core.ts"
  ],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
